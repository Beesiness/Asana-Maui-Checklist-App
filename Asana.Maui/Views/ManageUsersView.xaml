<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.Views.ManageUsersView"
             Title="User Management"
            NavigatedFrom="ContentPage_NavigatedFrom"
            NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Text="Users" FontSize="Medium" Grid.Row="0"></Label>
            <ListView ItemsSource="{Binding Users}"
                      Grid.Row="1"
                      SelectedItem="{Binding SelectedUser}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding DisplayName}" Detail="{Binding Username}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Text="Add User" Grid.Row="2" Command="{Binding AddUserCommand}" />
            <Button Text="Edit User" Grid.Row="3" Command="{Binding EditUserCommand}"/>
            <Button Text="Delete User" Grid.Row="4" Command="{Binding DeleteUserCommand}"/>




        </Grid>
        <Button Text="Ok" Clicked="OkClicked"/>
        <Button Text="Cancel" Clicked="CancelClicked"/>
    </VerticalStackLayout>
</ContentPage>